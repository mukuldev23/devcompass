# Root-level convenience file. Copy values into server/.env and client/.env as needed.

# Server
NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/devio-tech-explorer
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173
ADMIN_API_KEY=replace-with-strong-api-key
LOG_LEVEL=info
REDIS_URL=
RESTRICT_PUBLIC_API_TO_ORIGINS=false
INGEST_ON_START=true
INGEST_BATCH_SIZE=30
REQUEST_TIMEOUT_MS=8000

# Client
VITE_API_BASE_URL=http://localhost:4000/api
